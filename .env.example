# Public canonical origin used by Metadata, sitemap and DTO links.
SITE_URL=http://127.0.0.1:3000

# Real x2api integration. Omit X2API_BASE_URL or set X2API_API_MODE=mock
# to retain the local mock adapter during isolated UI development.
X2API_BASE_URL=http://127.0.0.1:8080
X2API_API_MODE=backend

# Required only for production mock sessions. Use at least 32 random characters.
MOCK_SESSION_SECRET=replace-with-a-random-secret-of-at-least-32-characters
